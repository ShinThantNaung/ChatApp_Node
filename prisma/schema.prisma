// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id        Int      @id @unique @default(autoincrement())
  email     String   @unique
  name      String?
  mostPlayed String?
  winrate   Float?
  createdAt DateTime @default(now())
}

model squad{
  id        Int      @id @unique @default(autoincrement())
  name      String   @unique
  winrate   Float?
  createdAt DateTime @default(now())
}