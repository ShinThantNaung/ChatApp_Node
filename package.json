{
  "name": "chatapp_node",
  "version": "1.0.0",
  "description": "Node backend for chat app",
  "homepage": "https://github.com/ShinThantNaung/ChatApp_Node#readme",
  "bugs": {
    "url": "https://github.com/ShinThantNaung/ChatApp_Node/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShinThantNaung/ChatApp_Node.git"
  },
  "license": "ISC",
  "author": "Shin Thant Naung",
  "type": "commonjs",
  "main": "server.js",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "test": "npm run test:ping",
    "test:ping": "node --test src/module/ping/ping.service.test.js src/module/ping/ping.controller.test.js",
    "test:mlbb": "node --test src/module/mlbbAcademy/mlbbAcademy.services.test.js src/module/mlbbAcademy/mlbbAcademy.controller.test.js",
    "test:sockets": "node --test src/sockets/sockets.middleware.test.js src/sockets/handlers/guild.handler.test.js src/sockets/handlers/chat.handler.test.js",
    "test:guild": "node --test src/module/guild/guild.service.test.js src/module/guild/guild.controller.test.js",
    "test:auth": "node --test src/module/auth/services/auth.services.test.js src/module/auth/controllers/auth.controller.test.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mlbb-sdk": "^2.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "resend": "^6.12.0",
    "socket.io": "^4.8.3"
  }
}
